{
    "cSpell.words": [
        "autofocus",
        "nytimes",
        "oxfmt",
        "oxlint",
        "baram",
        "oleh ",
        "ziniak",
        "kravchenko",
        "gayed",
        "lukasz ",
        "szmit",
        "gergen",
    ],
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        ".env": ".env.*",
        ".eslintrc.cjs": ".eslintrc.*.cjs,.eslintignore",
        ".eslintrc.js": ".eslintrc.*.js,.eslintignore",
        ".eslintrc.json": ".eslintrc.*.json,.eslintignore",
        ".gitignore": ".gitkeep,.gitattributes",
        ".oxlintrc.json": ".oxfmtrc.json",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts, ${capture}.http",
        "*.json": "${capture}.js,${capture}.ts",
        "*.ts": "${capture}.js,${capture}.spec.ts,${capture}.spec-d.ts,${capture}.spec.tsx,${capture}.spec-d.tsx,${capture}.options.ts,${capture}.test.ts,${capture}.test-d.ts,${capture}.test.tsx,${capture}.test-d.tsx,${capture}.stories.ts,${capture}.stories.tsx,${capture}.mdx",
        "*.tsx": "${capture}.jsx,${capture}.spec.tsx,${capture}.spec-d.tsx,${capture}.test.tsx,${capture}.test-d.tsx,${capture}.stories.tsx,${capture}.stories.ts,${capture}.mdx",
        "package.json": "package-lock.json,yarn.lock,pnpm-lock.yaml",
        "tsconfig.json": "tsconfig.*.json,tsconfig.tsbuildinfo"
    },
    "files.associations": {
        ".env": "dotenv",
        ".env.*": "dotenv",
        "*.css": "tailwindcss"
    },
    "files.eol": "\n",
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/.turbo/**": true,
        "**/node_modules/*/**": true
    },
    "oxc.path.oxfmt": "./node_modules/.bin/oxfmt",
    "oxc.path.oxlint": "./node_modules/.bin/oxlint",
    "vite.autoStart": false,
    "vite.buildCommand": "pnpm build",
    "vite.port": 5173,
    "vite.showTerminal": true
}